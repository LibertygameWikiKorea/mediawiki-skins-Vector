{{!
	@typedef object footerItem
	@prop string id of list item element
	@prop string html of list item

	@typedef object footerRow
	@prop string class of list element
	@prop string id of list element
	@prop footerItem[] array-items

	string|null html-user-language-attributes a string of attribute HTML
	footerRow data-portlets.data-footer-info the info row
	footerRow data-portlets.data-footer-places the places row
	footerRow data-portlets.data-footer-icons the icons row
}}
{{! `role` is unnecessary but kept to support selectors in any gadgets or user styles and
	to mitigate a VoiceOver bug. }}
<footer id="footer" class="mw-footer" {{{html-user-language-attributes}}}>
	{{#data-portlets.data-footer-info}}{{>Footer__row}}{{/data-portlets.data-footer-info}}
	{{#data-portlets.data-footer-places}}{{>Footer__row}}{{/data-portlets.data-footer-places}}
	{{#data-portlets.data-footer-icons}}{{>Footer__row}}{{/data-portlets.data-footer-icons}}
</footer>
